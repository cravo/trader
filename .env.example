APP_NAME=monday-momentum-bot
DATABASE_PATH=/data/momentum.db

# Benchmarks by market
UK_BENCHMARK_TICKER=^FTSE
US_BENCHMARK_TICKER=^GSPC

# Trading setup
STARTING_CAPITAL=100
TARGET_PROFIT_PCT=5
STOP_LOSS_PCT=3

# Scoring weights
WEIGHT_WEEKLY_CHANGE=0.35
WEIGHT_RELATIVE_STRENGTH=0.30
WEIGHT_VOLUME_RATIO=0.20
WEIGHT_BREAKOUT=0.15
WEIGHT_CLOSE_STRENGTH=1.0

# Universe settings
INCLUDE_FTSE100=true
INCLUDE_FTSE250=true
INCLUDE_SP500=true
INCLUDE_NASDAQ100=true

MIN_PRICE_GBP=0.50
MIN_PRICE_USD=5.00
MIN_30D_AVG_VOLUME_UK=200000
MIN_30D_AVG_VOLUME_US=500000

# Data settings
LOOKBACK_PERIOD=3mo
BREAKOUT_LOOKBACK_DAYS=20

# Trade filters / regime rules
MIN_WEEKLY_CHANGE_PCT=0.0
MIN_RELATIVE_STRENGTH_PCT=0.0
MIN_VOLUME_RATIO=1.2
REQUIRE_BREAKOUT=true
USE_BENCHMARK_MA_FILTER=true
BENCHMARK_MA_DAYS=50
MARKET_REGIME_FILTER=true
MARKET_REGIME_MA=50
MARKET_REGIME_TICKER=^GSPC
USE_RS_UNIVERSE_FILTER=true
RS_UNIVERSE_PERCENT=20

# Trend filter
USE_TREND_FILTER=true
TREND_FAST_MA_DAYS=20
TREND_SLOW_MA_DAYS=50

# Volume filter
MIN_20D_AVG_VOLUME=1000000
MIN_20D_AVG_DOLLAR_VOLUME=50000000

MARKET_REGIME_FAST_MA=20
MARKET_REGIME_SLOW_MA=50

NEUTRAL_TARGET_PROFIT_PCT=4.5
BEARISH_TARGET_PROFIT_PCT=4.0

NEUTRAL_RS_UNIVERSE_PERCENT=15
BEARISH_RS_UNIVERSE_PERCENT=10

NEUTRAL_MIN_WEEKLY_CHANGE_PCT=0.5
BEARISH_MIN_WEEKLY_CHANGE_PCT=1.0

NEUTRAL_MIN_RELATIVE_STRENGTH_PCT=1.0
BEARISH_MIN_RELATIVE_STRENGTH_PCT=2.0

NEUTRAL_MIN_VOLUME_RATIO=1.4
BEARISH_MIN_VOLUME_RATIO=1.6

NEUTRAL_REQUIRE_BREAKOUT=true
BEARISH_REQUIRE_BREAKOUT=true

# Notification
WEBHOOK_URL=
WEBHOOK_USERNAME=Monday Momentum Bot


# Runtime
MAX_CANDIDATES=25
DRY_RUN=false


